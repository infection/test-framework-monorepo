{
    "license": "proprietary",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Infection\\PhpSpecAdapter\\E2ETests\\PhpSpec\\": "src"
        },
        "files": [
            "src/Covered/functions.php",
            "src/Uncovered/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "spec\\Infection\\PhpSpecAdapter\\E2ETests\\PhpSpec\\": "spec",
            "Infection\\PhpSpecAdapter\\E2ETests\\PhpSpec\\Test\\": "tests"
        }
    },
    "require": {
        "php": "^8.2"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../infection",
            "options": {
                "versions": {
                    "infection/infection": "0.32.99"
                }
            }
        },
        {
            "type": "path",
            "url": "../../phpspec-adapter",
            "options": {
                "versions": {
                    "infection/phpspec-adapter": "0.3.99"
                }
            }
        }
    ],
    "require-dev": {
        "friends-of-phpspec/phpspec-code-coverage": "*",
        "infection/infection": "^0.32.6",
        "infection/phpspec-adapter": "^0.3.0",
        "phpunit/phpunit": "^11.5"
    }
}
