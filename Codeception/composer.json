{
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "^3.0.0"
    },
    "autoload": {
        "psr-4": {
            "Codeception_Basic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codeception_Basic\\Test\\": "tests/"
        }
    },
    "require": {
        "infection/infection": "@dev",
        "infection/codeception-adapter": "@dev"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "repositories": [{
        "name": "infection",
        "type": "path",
        "url": "../infection",
        "options": {
            "symlink": true,
            "versions": {
                "infection/infection": "0.32.99"
            }
        }
    },{
        "name": "codeception-adapter",
        "type": "path",
        "url": "../codeception-adapter",
        "options": {
            "symlink": true,
            "versions": {
                "infection/codeception-adapter": "0.4.99"
            }
        }
    }]
}
