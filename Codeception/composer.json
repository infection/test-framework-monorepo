{
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "^3.0.0"
    },
    "autoload": {
        "psr-4": {
            "Codeception_Basic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codeception_Basic\\Test\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../infection",
            "options": {
                "versions": {
                    "infection/infection": "0.32.99"
                }
            }
        },
        {
            "type": "path",
            "url": "../../phpspec-adapter",
            "options": {
                "versions": {
                    "infection/phpspec-adapter": "0.3.99"
                }
            }
        }
    ],
    "require": {
        "infection/infection": "@dev",
        "infection/codeception-adapter": "@dev"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
